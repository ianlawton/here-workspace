<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>BloombergProxy</AssemblyName>
    <RootNamespace>BloombergProxy</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Sdcb.FFmpeg" Version="6.0.0" />
    <PackageReference Include="Sdcb.FFmpeg.runtime.windows-x64" Version="6.0.0" />
  </ItemGroup>

</Project>
